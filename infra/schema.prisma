generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model CharacterSheet {
  id                 String         @id @default(cuid())
  name               String
  tagline            String?
  personality        String?        @db.Text
  background         String?        @db.Text
  appearance         String?        @db.Text
  scenario           String?        @db.Text
  customInstructions String?        @db.Text
  createdAt          DateTime       @default(now()) @db.Timestamptz(6)
  updatedAt          DateTime       @updatedAt @db.Timestamptz(6)
  conversations      Conversation[]
}

model LoreEntry {
  id              String                  @id @default(cuid())
  title           String
  type            String
  tags            String[]
  body            String                  @db.Text
  activationHints String[]
  isGlobal        Boolean                 @default(true)
  createdAt       DateTime                @default(now()) @db.Timestamptz(6)
  updatedAt       DateTime                @updatedAt @db.Timestamptz(6)
  conversations   ConversationLoreEntry[]
}

model Tag {
  id            String            @id @default(cuid())
  name          String            @unique
  color         String            @default("#6b7280")
  createdAt     DateTime          @default(now()) @db.Timestamptz(6)
  conversations ConversationTag[]
}

model Conversation {
  id                  String              @id @default(cuid())
  title               String              @default("New conversation")
  systemPrompt        String?             @db.Text
  model               String              @default("aion-labs/aion-2.0")
  autoLoreEnabled     Boolean             @default(true)
  promptBudgetMode    String              @default("balanced")
  summaryInvalidatedAt DateTime?          @db.Timestamptz(6)
  summaryRefreshError String?             @db.Text
  characterSheetId    String?
  archivedAt          DateTime?           @db.Timestamptz(6)
  characterSheet      CharacterSheet?     @relation(fields: [characterSheetId], references: [id], onDelete: SetNull)
  createdAt           DateTime            @default(now()) @db.Timestamptz(6)
  updatedAt           DateTime            @updatedAt @db.Timestamptz(6)
  messages            Message[]
  loreEntries         ConversationLoreEntry[]
  tags                ConversationTag[]
  summary             ConversationSummary?
}

model ConversationTag {
  conversationId String
  tagId          String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  tag            Tag          @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([conversationId, tagId])
  @@index([tagId])
}

model ConversationSummary {
  id                  String       @id @default(cuid())
  conversationId      String       @unique
  sourceMessageId     String
  coveredMessageCount Int
  summary             String       @db.Text
  stateSnapshot       Json?
  createdAt           DateTime     @default(now()) @db.Timestamptz(6)
  updatedAt           DateTime     @updatedAt @db.Timestamptz(6)
  conversation        Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
}

model ConversationLoreEntry {
  conversationId String
  loreEntryId    String
  pinned         Boolean      @default(false)
  priority       Int          @default(0)
  createdAt      DateTime     @default(now()) @db.Timestamptz(6)
  updatedAt      DateTime     @updatedAt @db.Timestamptz(6)
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  loreEntry      LoreEntry    @relation(fields: [loreEntryId], references: [id], onDelete: Cascade)

  @@id([conversationId, loreEntryId])
  @@index([loreEntryId])
  @@index([conversationId, priority])
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  role           String
  content        String
  reasoningDetails Json?
  createdAt      DateTime     @default(now()) @db.Timestamptz(6)
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
}
